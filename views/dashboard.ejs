<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Basic Dashboard</title>
    <style>
        :root {
            --bg: #0f1220;
            --panel: #151a2c;
            --panel-2: #1b2238;
            --text: #e6e9f2;
            --muted: #9aa3b2;
            --accent: #3b82f6;
            --accent-2: #2563eb;
            --success: #22c55e;
            --shadow: 0 10px 25px rgba(0, 0, 0, .25);
            --radius: 16px;
        }

        /* Reset / base */
        * {
            box-sizing: border-box;
        }

        html,
        body {
            height: 100%;
        }

        body {
            margin: 0;
            font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
            color: var(--text);
            background: radial-gradient(1200px 600px at 10% -10%, #1a2040, transparent) no-repeat,
                radial-gradient(1000px 500px at 120% 10%, #1a2040, transparent) no-repeat,
                var(--bg);
            line-height: 1.5;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        button {
            font: inherit;
        }

        /* Layout */
        .app {
            display: grid;
            grid-template-columns: 260px 1fr;
            grid-template-rows: 64px 1fr;
            grid-template-areas:
                "sidebar header"
                "sidebar main";
            min-height: 100dvh;
        }

        /* Sidebar */
        .sidebar {
            grid-area: sidebar;
            background: linear-gradient(180deg, var(--panel), var(--panel-2));
            border-right: 1px solid rgba(255, 255, 255, .06);
            padding: 20px 16px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 700;
            letter-spacing: .3px;
            margin-bottom: 20px;
        }

        .brand .logo {
            width: 34px;
            height: 34px;
            display: grid;
            place-items: center;
            border-radius: 10px;
            background: #1f2542;
            box-shadow: var(--shadow);
        }

        .nav {
            display: grid;
            gap: 6px;
            margin-top: 10px;
        }

        .nav a {
            padding: 12px 12px;
            border-radius: 12px;
            color: var(--muted);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .nav a:hover,
        .nav a.active {
            background: rgba(59, 130, 246, .12);
            color: var(--text);
        }

        .spacer {
            height: 10px;
        }

        /* Header */
        .header {
            grid-area: header;
            backdrop-filter: blur(6px);
            background: rgba(15, 18, 32, .35);
            border-bottom: 1px solid rgba(255, 255, 255, .06);
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 0 16px;
        }

        .hamburger {
            display: none;
            width: 40px;
            height: 40px;
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, .08);
            background: rgba(255, 255, 255, .02);
        }

        .search {
            flex: 1;
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(255, 255, 255, .04);
            border: 1px solid rgba(255, 255, 255, .08);
            padding: 10px 12px;
            border-radius: 12px;
            color: var(--muted);
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: linear-gradient(135deg, #334155, #1f2937);
            border: 1px solid rgba(255, 255, 255, .1);
        }

        /* Main */
        .main {
            grid-area: main;
            padding: 18px;
            display: grid;
            gap: 18px;
            grid-template-columns: repeat(12, 1fr);
            align-content: start;
        }

        /* Cards */
        .card {
            background: linear-gradient(180deg, var(--panel), #11162a);
            border: 1px solid rgba(255, 255, 255, .06);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            padding: 16px;
        }

        .card h3 {
            margin: 0 0 8px;
            font-size: 1rem;
        }

        .muted {
            color: var(--muted);
            font-size: .9rem;
        }

        .kpi {
            display: grid;
            gap: 4px;
        }

        .kpi .value {
            font-size: 1.8rem;
            font-weight: 700;
        }

        .cards {
            display: contents;
        }

        .cards .card {
            grid-column: span 3;
            min-height: 110px;
        }

        .wide {
            grid-column: span 8;
        }

        .tall {
            grid-column: span 4;
        }

        /* Connect Facebook button */
        .btn-fb {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 12px 16px;
            background: #1877F2;
            border: none;
            color: #fff;
            border-radius: 12px;
            font-weight: 600;
            box-shadow: 0 8px 18px rgba(24, 119, 242, .35);
            cursor: pointer;
            transition: transform .08s ease, box-shadow .2s ease, background .2s ease;
        }

        .btn-fb:hover {
            background: #166fe0;
            box-shadow: 0 10px 20px rgba(24, 119, 242, .45);
        }

        .btn-fb:active {
            transform: translateY(1px);
        }

        .btn-ghost {
            background: transparent;
            border: 1px solid rgba(255, 255, 255, .12);
            color: var(--text);
            padding: 10px 12px;
            border-radius: 10px;
        }

        /* Table */
        .table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 8px;
            font-size: .95rem;
        }

        .table th,
        .table td {
            text-align: left;
            padding: 12px;
            border-bottom: 1px solid rgba(255, 255, 255, .06);
        }

        .table tr:hover td {
            background: rgba(255, 255, 255, .02);
        }

        /* Responsive */
        @media (max-width: 1000px) {
            .cards .card {
                grid-column: span 6;
            }

            .wide {
                grid-column: span 12;
            }

            .tall {
                grid-column: span 12;
            }
        }

        @media (max-width: 780px) {
            .app {
                grid-template-columns: 1fr;
                grid-template-rows: 64px auto 1fr;
                grid-template-areas:
                    "header"
                    "sidebar"
                    "main";
            }

            .hamburger {
                display: inline-grid;
                place-items: center;
            }

            /* simple show/hide with checkbox */
            #menu-toggle:not(:checked)~.sidebar {
                display: none;
            }

            #menu-toggle:checked~.sidebar {
                display: block;
            }

            .sidebar {
                position: relative;
                z-index: 10;
                border-right: none;
                border-bottom: 1px solid rgba(255, 255, 255, .06);
            }
        }

        /* Prefers color scheme light (optional) */
        @media (prefers-color-scheme: light) {
            :root {
                --bg: #f6f7fb;
                --panel: #ffffff;
                --panel-2: #f9fafc;
                --text: #0f172a;
                --muted: #5b6475;
            }

            .search {
                background: #f3f5f9;
            }

            .avatar {
                border-color: rgba(0, 0, 0, .06);
            }
        }
    </style>
</head>

<body>
    <!-- Checkbox for mobile sidebar toggle -->
    <input type="checkbox" id="menu-toggle" hidden>

    <div class="app">
        <!-- Sidebar -->
        <aside class="sidebar" aria-label="Sidebar">
            <div class="brand">
                <div class="logo" aria-hidden="true">
                    <!-- simple mark -->
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M4 12L12 4l8 8-8 8-8-8Z" stroke="white" stroke-opacity=".9" stroke-width="2" />
                        <circle cx="12" cy="12" r="2.5" fill="white" fill-opacity=".9" />
                    </svg>
                </div>
                <span>My CRM Dashboard</span>
            </div>

            <nav class="nav">
                <a class="active" href="#">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M3 12L12 3l9 9v8a1 1 0 0 1-1 1h-5v-6H9v6H4a1 1 0 0 1-1-1v-8Z" stroke="currentColor"
                            stroke-width="1.7" />
                    </svg>
                    Dashboard
                </a>
                <a href="#">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M4 7h16M4 12h16M4 17h10" stroke="currentColor" stroke-width="1.7"
                            stroke-linecap="round" />
                    </svg>
                    Leads
                </a>
                <a href="#">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M3 5h18v14l-6-4-3 2-3-2-6 4V5Z" stroke="currentColor" stroke-width="1.7"
                            stroke-linejoin="round" />
                    </svg>
                    Messages
                </a>
                <a href="#">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path
                            d="M12 15.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7ZM19.4 15a7.96 7.96 0 0 0 0-6m-14.8 6a7.96 7.96 0 0 1 0-6"
                            stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                    </svg>
                    Analytics
                </a>
                <div class="spacer"></div>
                <a href="#">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M12 16v-4m0-4h.01M4 7h16v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7Z" stroke="currentColor"
                            stroke-width="1.7" stroke-linecap="round" />
                    </svg>
                    Help & Docs
                </a>
                <a href="#">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M12 15a3 3 0 1 0 0-6m7 3a7 7 0 1 1-14 0 7 7 0 0 1 14 0Zm2 0h2M3 12H1M12 3V1m0 22v-2"
                            stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                    </svg>
                    Settings
                </a>
            </nav>
        </aside>

        <!-- Header -->
        <header class="header" aria-label="Header">
            <label for="menu-toggle" class="hamburger" title="Toggle menu" aria-label="Toggle menu">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
            </label>

            <div class="search" role="search">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M21 21l-4.35-4.35M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15Z" stroke="currentColor"
                        stroke-width="1.7" stroke-linecap="round" />
                </svg>
                <span>Search…</span>
            </div>

            <div class="header-actions">
                <!-- Connect Facebook button in header -->
                <a href="/facebook/connect">
                    <button class="btn-fb" type="button" aria-label="Connect Facebook">
                        <!-- Facebook logo (SVG) -->
                        <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
                            <path fill="white"
                                d="M22 12.06C22 6.55 17.52 2 12 2S2 6.55 2 12.06c0 5 3.66 9.14 8.44 9.94v-7.03H7.9v-2.91h2.54V9.41c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.23.2 2.23.2v2.46h-1.26c-1.24 0-1.63.78-1.63 1.58v1.9h2.78l-.44 2.91h-2.34V22c4.78-.8 8.44-4.94 8.44-9.94Z" />
                        </svg>
                        Connect Facebook
                    </button>
                </a>


                <button class="btn-ghost" type="button">+ New</button>
                <div class="avatar" aria-hidden="true"></div>
            </div>
        </header>

        <!-- Main -->
        <main class="main" aria-label="Main content">
            <!-- KPI cards -->
            <section class="cards">
                <div class="card kpi">
                    <span class="muted">New Leads (7d)</span>
                    <span class="value">128</span>
                    <span class="muted">+12% vs last week</span>
                </div>
                <div class="card kpi">
                    <span class="muted">Conversions</span>
                    <span class="value">34</span>
                    <span class="muted">+4 today</span>
                </div>
                <div class="card kpi">
                    <span class="muted">Open Tickets</span>
                    <span class="value">9</span>
                    <span class="muted">SLA: 3h</span>
                </div>
                <div class="card kpi">
                    <span class="muted">Revenue</span>
                    <span class="value">₹1.8L</span>
                    <span class="muted">MTD</span>
                </div>
            </section>

            <!-- Wide card with CTA -->
            <section class="card wide">
                <h3>Connect your Facebook account</h3>
                <p class="muted">Bring Meta Leads directly into your CRM in real-time. Click below to connect.</p>
                <div style="margin-top: 10px; display:flex; gap:10px; flex-wrap: wrap;">
                    <button class="btn-fb" type="button" aria-label="Connect Facebook (main)">
                        <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
                            <path fill="white"
                                d="M22 12.06C22 6.55 17.52 2 12 2S2 6.55 2 12.06c0 5 3.66 9.14 8.44 9.94v-7.03H7.9v-2.91h2.54V9.41c